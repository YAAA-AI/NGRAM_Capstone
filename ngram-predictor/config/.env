# N-gram Text Predictor Configuration
# ------------------------------------

TRAIN_RAW_DIR=data/raw/train/
EVAL_RAW_DIR=data/raw/eval/
TRAIN_TOKENS=data/processed/train_tokens.txt
EVAL_TOKENS=data/processed/eval_tokens.txt
MODEL=data/model/model.json
VOCAB=data/model/vocab.json
UNK_THRESHOLD=3
TOP_K=3
NGRAM_ORDER=4

# Smoothing method: "mle-backoff" (MLE backoff with unigram fallback, default)
# or "katz" (Katz backoff with Good-Turing discounting)
SMOOTHING=mle-backoff

# LOG_LEVEL=INFO
